PANEL_BIND_HOST="127.0.0.1"
PANEL_BIND_PORT="8710"
PANEL_BASE_PATH="/panel"
# REQUIRED: Set to a random 32+ character string (e.g. python3 -c "import secrets; print(secrets.token_hex(32))")
APP_SECRET_KEY=""
SESSION_COOKIE_NAME="conan_panel_session"
CONAN_MANAGER_PATH="/home/conan/conanserver.sh"
PANEL_RUNTIME_USER="conan"
PANEL_DB_HOST="127.0.0.1"
PANEL_DB_PORT="3306"
PANEL_DB_NAME="conan_panel"
PANEL_DB_USER="conan_panel"
# REQUIRED: Set to your MariaDB/MySQL password for the panel database user
PANEL_DB_PASSWORD=""
# DATABASE_URL is constructed automatically from the DB params above by the installer.
# Override here only if you need a custom connection string.
PANEL_COMMAND_TIMEOUT="1800"
# Optional: Steam Web API key for Workshop browser in the panel.
# Get one at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=""

# Email notifications. Use EMAIL_PROVIDER="smtp" for Gmail/SMTP or "resend" for Resend.
EMAIL_PROVIDER="off"
EMAIL_FROM=""
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_STARTTLS="true"
SMTP_USERNAME=""
SMTP_PASSWORD=""
RESEND_API_KEY=""
