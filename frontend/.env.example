# MSM Frontend (Vite) — Umgebungsvariablen
# Kopieren nach frontend/.env.local (empfohlen) oder frontend/.env
# WICHTIG: Keine Secrets, keine MSM_AGENT_TOKEN, keine DIS-Keys — alles landet im Bundle.

# ── API / WebSocket (Phase 4: entkoppeltes Hosting) ──
# Leer / auskommentiert = relative /api (Vite-Proxy → Backend oder Backend-SPA).
# Split local:  VITE_API_URL=http://127.0.0.1:8000
# Vercel prod:  VITE_API_URL=https://api.example.com
VITE_API_URL=

# Optional: WebSocket-Origin (Default: aus VITE_API_URL bzw. page origin abgeleitet).
# Beispiel: VITE_WS_URL=wss://api.example.com
VITE_WS_URL=
