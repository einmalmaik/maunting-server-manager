{
  "version": 1,
  "meta": {
    "id": "singra_backend",
    "name": "Singra Backend & Bot",
    "category": "bot",
    "author": "einmalmaik",
    "description": "Singra Discord Bot and API Backend Suite"
  },
  "runtime": {
    "image": "node:22-bookworm-slim",
    "workdir": "/data",
    "user": null,
    "env": {
      "NODE_ENV": "production",
      "API_PORT": "{WEB_PORT}"
    },
    "startup": "./start.sh",
    "startupProfiles": [],
    "ensureDirs": [],
    "requiredFiles": [],
    "configPatches": [],
    "stopGracePeriodSeconds": 30,
    "startupCheckSeconds": 5.0,
    "enableExec": true,
    "execTimeoutSeconds": 120
  },
  "ports": [
    {
      "name": "web",
      "protocol": "tcp"
    }
  ],
  "source": {
    "type": "github",
    "updateStrategy": "checkBased",
    "steam": null,
    "http": null,
    "github": {
      "repo": "einmalmaik/Singra-Discord-bot",
      "branch": "master",
      "subPath": null,
      "setupCommands": [
        [
          "npm",
          "ci"
        ],
        [
          "npm",
          "run",
          "build:api"
        ],
        [
          "npm",
          "run",
          "build:bot"
        ],
        [
          "chmod",
          "+x",
          "start.sh"
        ]
      ]
    },
    "manual": null
  },
  "mods": null,
  "backup": null
}