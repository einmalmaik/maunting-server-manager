# Maunting Server Manager — Agent-/Node-Konfiguration
#
# Empfohlen: Remote-Node im Panel hinzufügen und den dort erzeugten Einmal-Befehl
# ausführen. helper-scripts/install-msm-agent.sh erzeugt Token, TLS-Zertifikat, Pfade und
# systemd-Service automatisch. Für eine manuelle Installation:
#   cp msm-agent/.env.example msm-agent/.env
#   chmod 600 msm-agent/.env
# Beim Aufteilen einer bestehenden All-in-one-Installation übernimmt
# helper-scripts/migrate-panel-components.sh diesen Enrollment-/Handoff-Pfad. Der Agent nutzt
# danach weiterhin /opt/msm/servers und denselben Rootless-Docker-Runtime; Tokens
# oder Zertifikatsfingerprints müssen nicht manuell aus einer .env kopiert werden.
#
# Niemals msm-agent/.env, Tokens, Zertifikatsschlüssel oder DB-Passwörter committen.
# Datenbankpasswörter und S3-Zugangsdaten werden absichtlich nicht dauerhaft auf
# dem Agent gespeichert; das Panel sendet sie nur im Arbeitsspeicher pro Request.
#
# Status-Legende: AUTOMATISCH, PFLICHT, OPTIONAL, STANDARD oder ERWEITERT.

# Status: AUTOMATISCH / bei manueller Installation PFLICHT
# Zweck: Bearer-Token für sämtliche Agent-Endpunkte außer /health.
# Herkunft: Enrollment/Installer erzeugt ihn. Manuell:
#   openssl rand -base64 48 | tr -d '\n=/+' | head -c 48; echo
# Der identische Token wird vom Panel DIS-verschlüsselt gespeichert. Nie per URL teilen.
MSM_AGENT_TOKEN=change-me-to-a-long-random-secret

# Status: AUTOMATISCH / bei manueller Installation PFLICHT
# Zweck: Adresse, auf der der Agent lauscht.
# Herkunft: Remote-Node 0.0.0.0 nur zusammen mit TLS und Firewall; lokaler Agent 127.0.0.1.
MSM_AGENT_HOST=127.0.0.1

# Status: AUTOMATISCH
# Zweck: HTTPS-/HTTP-Port des Agents.
# Herkunft: 9000 ist Standard. Nur bei Portkollision ändern und denselben Port
# in Host-/Cloud-Firewall sowie Panel-Node-URL verwenden.
MSM_AGENT_PORT=9000

# Status: AUTOMATISCH
# Zweck: Sicherheitsgrenze und Stammverzeichnis aller Gameserver-Dateien dieses Nodes.
# Herkunft: Installer nutzt /opt/msm/servers. Pfad muss lokal, persistent und für
# den msm-Benutzer beschreibbar sein; niemals zwischen Nodes gemeinsam mounten.
MSM_SERVERS_DIR=/opt/msm/servers

# Status: AUTOMATISCH / ERWEITERT
# Zweck: Rootless-Docker-Socket des Agent-Benutzers.
# Herkunft: Installer setzt unix:///run/user/<UID>/docker.sock.
# Leer = Agent ermittelt den Rootless-Standard. Kein öffentliches TCP-Docker-API verwenden.
MSM_DOCKER_HOST=

# Status: STANDARD
# Zweck: Minimale Log-Stufe: DEBUG, INFO, WARNING oder ERROR.
# Herkunft: INFO ist Produktionsempfehlung. DEBUG kann Infrastrukturdetails erzeugen
# und sollte nur kurzfristig zur Diagnose aktiviert werden.
MSM_AGENT_LOG_LEVEL=INFO

# Status: AUTOMATISCH
# Zweck: Vom Agent gemeldete Runtime-Version.
# Herkunft: Release/Installer; nicht manuell vortäuschen oder unabhängig vom Code ändern.
MSM_AGENT_VERSION=1.0.0

# Status: STANDARD (Sicherheitsgrenze)
# Zweck: Nur Container mit diesem Präfix dürfen als Gameserver verwaltet werden.
# Herkunft: Projektstandard. Nach Erstellung von Servern nicht ändern.
MSM_CONTAINER_NAME_PREFIX=msm-srv-

# Status: ERWEITERT
# Zweck: Standard-Wartezeit beim geordneten Stoppen eines Containers in Sekunden.
# Herkunft: 30 Sekunden; spielbezogene Blueprints können eigene Werte vorgeben.
MSM_DEFAULT_STOP_TIMEOUT=30

# Status: ERWEITERT
# Zweck: Maximale Größe eines normalen Datei-Uploads in Bytes.
# Herkunft: 104857600 = 100 MiB. Große Uploads verwenden den Chunk-Flow.
MSM_MAX_UPLOAD_SIZE=104857600

# Status: ERWEITERT
# Zweck: Maximale Größe einer als Text gelesenen Datei in Bytes.
# Herkunft: 5242880 = 5 MiB; schützt Agent und Panel vor Speicherüberlastung.
MSM_MAX_READ_SIZE=5242880

# ── TLS für Remote-Nodes ─────────────────────────────────────────────────

# Status: AUTOMATISCH / bei manueller Remote-Installation PFLICHT
# Zweck: Öffentliches Zertifikat für Agent-HTTPS.
# Herkunft: helper-scripts/install-msm-agent.sh erzeugt ein selbstsigniertes Zertifikat und
# das Panel pinnt dessen SHA-256-Fingerprint. Manueller Pfad muss lesbar sein.
MSM_TLS_CERTFILE=

# Status: AUTOMATISCH / bei manueller Remote-Installation PFLICHT
# Zweck: Privater Schlüssel des Agent-Zertifikats.
# Herkunft: Installer erzeugt ihn mit Modus 600. Niemals kopieren, loggen oder committen.
# Zertifikat und Key müssen gemeinsam gesetzt sein; sonst startet der Agent ohne TLS.
MSM_TLS_KEYFILE=

# ── Verwaltetes PostgreSQL dieses Nodes ──────────────────────────────────
# Pro physischem Node läuft genau ein verwalteter PostgreSQL-Container. Darin
# erhält jeder Gameserver eigene DBs/Rollen. Gleiche Namen/Ports auf verschiedenen
# Hosts sind erlaubt; nur lokale Kollisionen auf demselben Host erfordern Änderungen.

# Status: STANDARD
# Zweck: Offizielles PostgreSQL-Image.
# Herkunft: Projektstandard; Versionswechsel nur mit getesteter Migration.
MSM_MANAGED_POSTGRES_IMAGE=postgres:17-alpine

# Status: STANDARD
# Zweck: Containername und interner DNS-Hostname auf diesem Node.
# Herkunft: Projektstandard; nicht mit einem fremden Container teilen.
MSM_MANAGED_POSTGRES_CONTAINER_NAME=msm-postgres

# Status: STANDARD
# Zweck: Internes Docker-Netz zwischen Gameservern und PostgreSQL.
# Herkunft: Agent legt es automatisch an; nicht öffentlich erreichbar machen.
MSM_MANAGED_POSTGRES_NETWORK=msm-internal

# Status: STANDARD (Sicherheitsgrenze)
# Zweck: Loopback-Bind-Adresse für Verwaltungszugriffe des Agents.
# Herkunft: Muss 127.0.0.1 bleiben; andere Werte werden sicherheitshalber abgelehnt.
MSM_MANAGED_POSTGRES_HOST=127.0.0.1

# Status: ERWEITERT
# Zweck: Lokaler Loopback-Port von PostgreSQL auf diesem Node.
# Herkunft: 15432; nur bei einer lokalen Portkollision ändern.
MSM_MANAGED_POSTGRES_PORT=15432

# Status: AUTOMATISCH
# Zweck: Persistenter Datenpfad des PostgreSQL-Containers.
# Herkunft: Installer nutzt /opt/msm/postgres. Nicht löschen, nicht zwischen Nodes teilen,
# regelmäßig zusammen mit den Panel-Metadaten sichern.
MSM_MANAGED_POSTGRES_DATA_DIR=/opt/msm/postgres

# Status: ERWEITERT
# Zweck: Maximale Laufzeit frei eingegebener SQL-Anweisungen in Millisekunden.
# Herkunft: 5000 ms ist der Sicherheitsstandard; Erhöhung steigert Last-/DoS-Risiko.
MSM_MANAGED_POSTGRES_STATEMENT_TIMEOUT_MS=5000

# Status: ERWEITERT
# Zweck: Maximale Zeilenzahl einer SQL-Ergebnisansicht.
# Herkunft: 500 ist der Speicher-/UI-Sicherheitsstandard.
MSM_MANAGED_POSTGRES_ROW_LIMIT=500

# Status: STANDARD (Sicherheits-Allowlist)
# Zweck: PostgreSQL-Erweiterungen, die DB-Owner selbst aktivieren dürfen.
# Herkunft: Muss mit der geprüften Backend-Allowlist übereinstimmen. Normalerweise
# nicht ändern; Erweiterungen nur nach Code-/Security-Review ergänzen.
# Format: komma-separierte Extension-Namen ohne Leerzeichen.
MSM_TRUSTED_POSTGRES_EXTENSIONS=pgcrypto,uuid-ossp,citext,btree_gin,btree_gist,fuzzystrmatch,hstore,pg_trgm,tablefunc,unaccent,isn,lo,ltree,tcn

# S3/MinIO-Zugangsdaten, Backup-Passwörter, Gameserver-DB-Passwörter und Steam-
# Zugangsdaten gehören absichtlich nicht in die Agent-.env. Sie werden im Panel
# verwaltet und nur kurzzeitig für die konkrete Operation an den Agent übertragen.

# Status: AUTOMATISCH
# Zweck: Verzeichnis für die persistenten Guardian-Zustands- und Vorfallsdateien.
# Herkunft: /var/lib/msm-agent/guardian
MSM_GUARDIAN_STATE_DIR=/var/lib/msm-agent/guardian

# Status: STANDARD
# Zweck: Loop-Intervall des Guardian-Hauptthreads in Sekunden.
# Herkunft: 5.0 Sekunden Standard.
MSM_GUARDIAN_LOOP_INTERVAL_SECONDS=5.0
