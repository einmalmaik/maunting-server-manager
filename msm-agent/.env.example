# MSM Agent configuration (copy to .env and fill in)
# NEVER commit real tokens. install-agent.sh generates production values.

# Required: static bearer token for all authenticated endpoints
MSM_AGENT_TOKEN=change-me-to-a-long-random-secret

# Bind address / port
# Production remote: 0.0.0.0 + TLS. Local dev: 127.0.0.1
MSM_AGENT_HOST=127.0.0.1
MSM_AGENT_PORT=9000

# Root directory for game-server files (path traversal is enforced against this)
MSM_SERVERS_DIR=./servers

# Optional: override Docker socket (default: rootless unix:///run/user/UID/docker.sock)
# Leer = Rootless-Default des laufenden Users.
MSM_DOCKER_HOST=

# Log level: DEBUG, INFO, WARNING, ERROR
MSM_AGENT_LOG_LEVEL=INFO
MSM_AGENT_VERSION=1.0.0
MSM_CONTAINER_NAME_PREFIX=msm-srv-
MSM_DEFAULT_STOP_TIMEOUT=30
MSM_MAX_UPLOAD_SIZE=104857600
MSM_MAX_READ_SIZE=5242880

# ── TLS (Phase 5 — required for remote nodes) ──
# Self-signed cert + key. Panel stores SHA-256 fingerprint of the cert.
# MSM_TLS_CERTFILE=/opt/msm-agent/certs/agent.crt
# MSM_TLS_KEYFILE=/opt/msm-agent/certs/agent.key
MSM_TLS_CERTFILE=
MSM_TLS_KEYFILE=

# Phase 6: S3 credentials are NEVER stored on the agent.
# Panel passes ephemeral S3 config + encryption key only in memory per request.

# Phase 7: Managed Postgres (local container; passwords only in RAM from panel)
MSM_MANAGED_POSTGRES_IMAGE=postgres:17-alpine
MSM_MANAGED_POSTGRES_CONTAINER_NAME=msm-postgres
MSM_MANAGED_POSTGRES_NETWORK=msm-internal
MSM_MANAGED_POSTGRES_HOST=127.0.0.1
MSM_MANAGED_POSTGRES_PORT=15432
MSM_MANAGED_POSTGRES_DATA_DIR=/opt/msm/postgres
MSM_MANAGED_POSTGRES_STATEMENT_TIMEOUT_MS=5000
MSM_MANAGED_POSTGRES_ROW_LIMIT=500
