# Force LF line endings for shell scripts on all platforms
*.sh            text eol=lf

# Python files — LF
*.py            text eol=lf

# Web / config — LF
*.ts            text eol=lf
*.tsx           text eol=lf
*.js            text eol=lf
*.jsx           text eol=lf
*.css           text eol=lf
*.html          text eol=lf
*.json          text eol=lf
*.yaml          text eol=lf
*.yml           text eol=lf
*.toml          text eol=lf
*.ini           text eol=lf
*.conf          text eol=lf
*.cfg           text eol=lf
*.tpl           text eol=lf
*.md            text eol=lf
*.txt           text eol=lf
*.sql           text eol=lf
.env.example    text eol=lf
Makefile        text eol=lf

# Binary — no conversion
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.ico           binary
*.woff          binary
*.woff2         binary
*.ttf           binary
*.eot           binary
*.pdf           binary
*.zip           binary
*.tar           binary
*.gz            binary
