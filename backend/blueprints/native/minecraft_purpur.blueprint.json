{
  "version": 1,
  "meta": {
    "id": "minecraft_purpur",
    "name": "Minecraft (Purpur)",
    "category": "non_steam_game",
    "author": "Maunting Studios",
    "description": "Purpur-Server via itzg/minecraft-server. Paper-Fork mit erweiterten Konfig-Optionen. Plugins in /data/plugins."
  },
  "runtime": {
    "image": "itzg/minecraft-server:latest",
    "workdir": "/data",
    "env": {
      "EULA": "TRUE",
      "TYPE": "PURPUR",
      "VERSION": "LATEST",
      "SERVER_PORT": "{GAME_PORT}",
      "ENABLE_RCON": "true",
      "RCON_PORT": "{RCON_PORT}"
    },
    "startup": "/start"
  },
  "ports": [
    { "name": "game",  "protocol": "tcp" },
    { "name": "query", "protocol": "udp" },
    { "name": "rcon",  "protocol": "tcp" }
  ],
  "source": {
    "type": "dockerOnly",
    "steam": null,
    "http": null
  },
  "mods": {
    "supportsMods": true,
    "supportsSteamWorkshop": false,
    "workshopAppId": null,
    "modInjection": "none",
    "modStartupArgumentFormat": null,
    "modListFilePath": null
  }
}
