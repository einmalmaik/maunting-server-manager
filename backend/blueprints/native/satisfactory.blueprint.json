{
  "version": 1,
  "meta": {
    "id": "satisfactory",
    "name": "Satisfactory",
    "category": "steam_game",
    "author": "Maunting Studios",
    "description": "Satisfactory Dedicated Server via SteamCMD (App-ID 526870). Nativer Linux-Support."
  },
  "runtime": {
    "image": "ghcr.io/parkervcp/steamcmd:debian",
    "workdir": "/data",
    "user": "1000:1000",
    "env": {
      "HOME": "/data",
      "LD_LIBRARY_PATH": ".:./linux64:/usr/lib32:/usr/lib/x86_64-linux-gnu"
    },
    "startup": "./FactoryServer.sh -Port={GAME_PORT}",
    "ensureDirs": [
      ".config/Epic/FactoryGame/Saved/SaveGames"
    ],
    "requiredFiles": [
      "FactoryServer.sh"
    ],
    "configPatches": [],
    "startupCheckSeconds": 120.0
  },
  "ports": [
    {
      "name": "game",
      "protocol": "udp"
    }
  ],
  "source": {
    "type": "steam",
    "steam": {
      "appId": "526870",
      "platform": "linux",
      "compatibility": "native",
      "requiresLogin": false,
      "validate": false
    },
    "updateStrategy": "checkBased"
  },
  "mods": {
    "supportsMods": false,
    "supportsSteamWorkshop": false,
    "workshopAppId": null,
    "modInjection": "none",
    "modStartupArgumentFormat": null,
    "modListFilePath": null,
    "modListContent": "workshopIds",
    "postInstall": []
  },
  "health": {
    "process": {},
    "application": {
      "type": "source-query",
      "port": "{{QUERY_PORT}}",
      "interval": "60s",
      "failure_threshold": 3
    },
    "startup": {
      "grace_period_seconds": 120,
      "success_patterns": [
        "Server startup time elapsed",
        "auto-pause is allowed to proceed from now on"
      ],
      "failure_patterns": [
        "Address already in use"
      ]
    }
  },
  "recovery": {
    "policies": [
      {
        "match": "process_not_running",
        "action": "restart"
      },
      {
        "match": "source_query_failed",
        "action": "restart"
      },
      {
        "match": "port-conflict",
        "action": "clear_declared_lock_files"
      },
      {
        "match": "linux-oom",
        "action": "graceful_restart"
      }
    ],
    "attempt_window_seconds": 600,
    "max_attempts": 3,
    "cooldown_seconds": 60
  },
  "backup": {
    "includePaths": [
      ".config/Epic/FactoryGame/Saved/SaveGames",
      ".config/Epic/FactoryGame/Saved/Config"
    ]
  },
  "logs": {
    "sources": [
      "FactoryGame/Saved/Logs/FactoryGame.log",
      "stdout"
    ],
    "redact": [
      "regex:ServerPassword"
    ]
  },
  "diagnostics": {
    "parsers": [
      "linux-oom",
      "port-conflict"
    ]
  }
}