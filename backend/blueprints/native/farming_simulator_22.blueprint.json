{
  "version": 1,
  "meta": {
    "id": "farming_simulator_22",
    "name": "Farming Simulator 22",
    "category": "steam_game",
    "author": "Maunting Studios",
    "description": "Farming Simulator 22 Dedicated Server via SteamCMD (App-ID 1782290). Runs on Windows-binary via GE-Proton/Wine."
  },
  "runtime": {
    "image": "ghcr.io/parkervcp/yolks:wine_10",
    "workdir": "/home/container",
    "user": "1000:1000",
    "env": {
      "WINEDEBUG": "-all",
      "WINEESYNC": "1",
      "WINEFSYNC": "1"
    },
    "startup": "./FarmingSimulator2022.exe -server",
    "ensureDirs": [
      "profile"
    ],
    "requiredFiles": [
      "FarmingSimulator2022.exe"
    ],
    "configPatches": [
      {
        "type": "regex",
        "file": "profile/dedicatedServerConfig.xml",
        "regex": "(<port>)\\d+(</port>)",
        "value": "\\g<1>{GAME_PORT}\\g<2>"
      }
    ],
    "startupCheckSeconds": 90.0
  },
  "ports": [
    {
      "name": "game",
      "protocol": "tcp"
    }
  ],
  "source": {
    "type": "steam",
    "steam": {
      "appId": "1782290",
      "platform": "windows",
      "compatibility": "proton",
      "requiresLogin": false,
      "validate": false
    },
    "updateStrategy": "checkBased"
  },
  "mods": {
    "supportsMods": false,
    "supportsSteamWorkshop": false,
    "workshopAppId": null,
    "modInjection": "none",
    "modStartupArgumentFormat": null,
    "modListFilePath": null,
    "modListContent": "workshopIds",
    "postInstall": []
  },
  "health": {
    "process": {},
    "application": {
      "type": "tcp",
      "port": "game",
      "interval": "60s",
      "failure_threshold": 3
    },
    "startup": {
      "grace_period_seconds": 60,
      "success_patterns": [
        "Game server started"
      ],
      "failure_patterns": [
        "Unable to start game server",
        "Address already in use"
      ]
    }
  },
  "logs": {
    "sources": [
      "profile/server.log",
      "stdout"
    ],
    "redact": [
      "regex:password",
      "regex:adminPassword"
    ]
  },
  "diagnostics": {
    "parsers": [
      "linux-oom",
      "port-conflict"
    ]
  },
  "recovery": {
    "policies": [
      {
        "match": "process_not_running",
        "action": "restart"
      },
      {
        "match": "tcp_connect_failed",
        "action": "restart"
      },
      {
        "match": "port-conflict",
        "action": "clear_declared_lock_files"
      },
      {
        "match": "linux-oom",
        "action": "graceful_restart"
      }
    ],
    "attempt_window_seconds": 600,
    "max_attempts": 3,
    "cooldown_seconds": 60
  },
  "backup": {
    "includePaths": [
      "profile"
    ]
  }
}