{
  "version": 1,
  "meta": {
    "id": "enshrouded",
    "name": "Enshrouded",
    "category": "steam_game",
    "author": "Maunting Studios",
    "description": "Enshrouded Dedicated Server via SteamCMD (App-ID 2278520). Nativer Linux-Support. Konfiguration erfolgt \u00c3\u00bcber enshrouded_server.json."
  },
  "runtime": {
    "image": "ghcr.io/parkervcp/steamcmd:debian",
    "workdir": "/data",
    "user": "1000:1000",
    "env": {
      "HOME": "/data",
      "LD_LIBRARY_PATH": ".:./linux64:/usr/lib32:/usr/lib/x86_64-linux-gnu"
    },
    "startup": "./enshrouded_server",
    "ensureDirs": [],
    "requiredFiles": [
      "enshrouded_server"
    ],
    "configPatches": [
      {
        "type": "regex",
        "file": "enshrouded_server.json",
        "regex": "(\"gamePort\"\\s*:\\s*)\\d+",
        "value": "\\g<1>{GAME_PORT}"
      },
      {
        "type": "regex",
        "file": "enshrouded_server.json",
        "regex": "(\"queryPort\"\\s*:\\s*)\\d+",
        "value": "\\g<1>{QUERY_PORT}"
      }
    ],
    "startupCheckSeconds": 60.0
  },
  "ports": [
    {
      "name": "game",
      "protocol": "udp"
    },
    {
      "name": "query",
      "protocol": "udp"
    }
  ],
  "source": {
    "type": "steam",
    "steam": {
      "appId": "2278520",
      "platform": "linux",
      "compatibility": "native",
      "requiresLogin": false,
      "validate": false
    },
    "updateStrategy": "checkBased"
  },
  "mods": {
    "supportsMods": false,
    "supportsSteamWorkshop": false,
    "workshopAppId": null,
    "modInjection": "none",
    "modStartupArgumentFormat": null,
    "modListFilePath": null,
    "modListContent": "workshopIds",
    "postInstall": []
  },
  "health": {
    "process": {},
    "application": {
      "type": "source-query",
      "port": "{{QUERY_PORT}}",
      "interval": "60s",
      "failure_threshold": 3
    },
    "startup": {
      "grace_period_seconds": 60,
      "success_patterns": [
        "HostSessionSuccess",
        "'HostOnline' (up)!"
      ],
      "failure_patterns": [
        "Address already in use",
        "Could not bind"
      ]
    }
  },
  "logs": {
    "sources": [
      "logs/enshrouded_server.log",
      "stdout"
    ],
    "redact": [
      "regex:password"
    ]
  },
  "diagnostics": {
    "parsers": [
      "linux-oom",
      "port-conflict"
    ]
  },
  "recovery": {
    "policies": [
      {
        "match": "process_not_running",
        "action": "restart"
      },
      {
        "match": "source_query_failed",
        "action": "restart"
      },
      {
        "match": "port-conflict",
        "action": "clear_declared_lock_files"
      },
      {
        "match": "linux-oom",
        "action": "graceful_restart"
      }
    ],
    "attempt_window_seconds": 600,
    "max_attempts": 3,
    "cooldown_seconds": 60
  },
  "backup": {
    "includePaths": [
      "enshrouded_server.json",
      "savegame"
    ]
  }
}