{
  "version": 1,
  "meta": {
    "id": "dayz",
    "name": "DayZ",
    "category": "steam_game",
    "author": "Maunting Studios",
    "description": "DayZ Linux Dedicated Server (App-ID 223350, Workshop 221100). Benötigt einen konfigurierten globalen Steam-Account unter Settings (Steam Guard muss deaktiviert sein)."
  },
  "runtime": {
    "image": "ghcr.io/parkervcp/steamcmd:debian",
    "workdir": "/data",
    "env": {
      "HOME": "/data",
      "LD_LIBRARY_PATH": ".:./linux64:/usr/lib32:/usr/lib/x86_64-linux-gnu"
    },
    "startup": "./DayZServer -config=serverDZ.cfg -port={GAME_PORT} -BEpath=battleye -profiles=profiles -dologs -adminlog -netlog -freezecheck {MOD_ARG}",
    "ensureDirs": ["profiles", "battleye", "keys"],
    "requiredFiles": ["DayZServer", "serverDZ.cfg"],
    "configPatches": [
      {
        "type": "regex",
        "file": "serverDZ.cfg",
        "regex": "(steamQueryPort\\s*=\\s*)\\d+;",
        "value": "\\g<1>{QUERY_PORT};"
      }
    ]
  },
  "ports": [
    { "name": "game",  "protocol": "udp" },
    { "name": "query", "protocol": "udp" },
    { "name": "rcon",  "protocol": "tcp" }
  ],
  "source": {
    "type": "steam",
    "steam": {
      "appId": "223350",
      "platform": "linux",
      "compatibility": "native",
      "requiresLogin": true
    }
  },
  "mods": {
    "supportsMods": true,
    "supportsSteamWorkshop": true,
    "workshopAppId": "221100",
    "modInjection": "startupArg",
    "modStartupArgumentFormat": "-mod={mods};",
    "modListFilePath": null,
    "modListContent": "workshopIds",
    "postInstall": [
      {
        "operation": "symlink",
        "source": "steamapps/workshop/content/{WORKSHOP_APP_ID}/{WORKSHOP_ID}",
        "target": "{WORKSHOP_ID}",
        "required": true
      },
      {
        "operation": "symlink",
        "source": "steamapps/workshop/content/{WORKSHOP_APP_ID}/{WORKSHOP_ID}/keys/*.bikey",
        "target": "keys/{BASENAME}",
        "required": false
      }
    ]
  }
}
