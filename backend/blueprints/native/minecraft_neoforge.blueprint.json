{
  "version": 1,
  "meta": {
    "id": "minecraft_neoforge",
    "name": "Minecraft (NeoForge)",
    "category": "non_steam_game",
    "author": "Maunting Studios",
    "description": "NeoForge-Server via itzg/minecraft-server. Community-Fork von Forge, fuer 1.20.4+ der neue Standard fuer Mod-Server. Mods (.jar) in /data/mods."
  },
  "runtime": {
    "image": "itzg/minecraft-server:latest",
    "workdir": "/data",
    "env": {
      "EULA": "TRUE",
      "TYPE": "NEOFORGE",
      "VERSION": "LATEST",
      "SERVER_PORT": "{GAME_PORT}",
      "ENABLE_RCON": "true",
      "RCON_PORT": "{RCON_PORT}"
    },
    "startup": "/start"
  },
  "ports": [
    {
      "name": "game",
      "protocol": "tcp"
    },
    {
      "name": "query",
      "protocol": "udp"
    },
    {
      "name": "rcon",
      "protocol": "tcp"
    }
  ],
  "source": {
    "type": "dockerOnly",
    "steam": null,
    "http": null
  },
  "mods": {
    "supportsMods": true,
    "supportsSteamWorkshop": false,
    "workshopAppId": null,
    "modInjection": "none",
    "modStartupArgumentFormat": null,
    "modListFilePath": null
  },
  "health": {
    "process": {},
    "application": {
      "type": "minecraft-status",
      "port": "{{GAME_PORT}}",
      "interval": "60s",
      "failure_threshold": 3
    },
    "startup": {
      "grace_period_seconds": 180,
      "success_patterns": [
        "Done \\(",
        "For help, type \"help\""
      ],
      "failure_patterns": [
        "FAILED TO BIND TO PORT",
        "Perhaps a server is already running on that port?"
      ]
    }
  },
  "recovery": {
    "policies": [
      {
        "match": "process_not_running",
        "action": "restart"
      },
      {
        "match": "minecraft_status_failed",
        "action": "restart"
      },
      {
        "match": "minecraft_query_failed",
        "action": "restart"
      },
      {
        "match": "port-conflict",
        "action": "clear_declared_lock_files"
      },
      {
        "match": "linux-oom",
        "action": "graceful_restart"
      }
    ],
    "attempt_window_seconds": 600,
    "max_attempts": 3,
    "cooldown_seconds": 60
  },
  "logs": {
    "sources": [
      "logs/latest.log",
      "stdout"
    ],
    "redact": [
      "regex:rcon\\.password"
    ]
  },
  "diagnostics": {
    "parsers": [
      "linux-oom",
      "port-conflict"
    ]
  }
}