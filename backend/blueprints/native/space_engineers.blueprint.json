{
  "version": 1,
  "meta": {
    "id": "space_engineers",
    "name": "Space Engineers",
    "category": "steam_game",
    "author": "Maunting Studios",
    "description": "Space Engineers Dedicated Server via SteamCMD (App-ID 298740). Runs on Windows-binary via GE-Proton/Wine. Steam Workshop (App-ID 244850)."
  },
  "runtime": {
    "image": "ghcr.io/parkervcp/yolks:wine_10",
    "workdir": "/home/container",
    "user": "1000:1000",
    "env": {
      "WINEDEBUG": "-all",
      "WINEESYNC": "1",
      "WINEFSYNC": "1"
    },
    "startup": "./DedicatedServer64/SpaceEngineersDedicated.exe -console -port {GAME_PORT}",
    "ensureDirs": [
      "config"
    ],
    "requiredFiles": [
      "DedicatedServer64/SpaceEngineersDedicated.exe"
    ],
    "configPatches": [
      {
        "type": "regex",
        "file": "config/SpaceEngineers-Dedicated.cfg",
        "regex": "(<ServerPort>)\\d+(</ServerPort>)",
        "value": "\\g<1>{GAME_PORT}\\g<2>"
      }
    ],
    "startupCheckSeconds": 90.0
  },
  "ports": [
    {
      "name": "game",
      "protocol": "udp"
    }
  ],
  "source": {
    "type": "steam",
    "steam": {
      "appId": "298740",
      "platform": "windows",
      "compatibility": "proton",
      "requiresLogin": false,
      "validate": false
    },
    "updateStrategy": "checkBased"
  },
  "mods": {
    "supportsMods": true,
    "supportsSteamWorkshop": true,
    "workshopAppId": "244850",
    "filterTags": [],
    "modInjection": "file",
    "modStartupArgumentFormat": null,
    "modListFilePath": "config/modlist.txt",
    "modListContent": "workshopIds",
    "postInstall": []
  },
  "health": {
    "process": {},
    "application": {
      "type": "source-query",
      "port": "{{QUERY_PORT}}",
      "interval": "60s",
      "failure_threshold": 3
    },
    "startup": {
      "grace_period_seconds": 120,
      "success_patterns": [
        "Game ready",
        "Press Ctrl+C to exit"
      ],
      "failure_patterns": [
        "Address already in use"
      ]
    }
  },
  "recovery": {
    "policies": [
      {
        "match": "process_not_running",
        "action": "restart"
      },
      {
        "match": "source_query_failed",
        "action": "restart"
      },
      {
        "match": "port-conflict",
        "action": "clear_declared_lock_files"
      },
      {
        "match": "linux-oom",
        "action": "graceful_restart"
      }
    ],
    "attempt_window_seconds": 600,
    "max_attempts": 3,
    "cooldown_seconds": 60
  },
  "backup": {
    "includePaths": [
      "config",
      "Saves"
    ]
  },
  "logs": {
    "sources": [
      "SpaceEngineersDedicated.log",
      "stdout"
    ],
    "redact": [
      "regex:ServerPassword"
    ]
  },
  "diagnostics": {
    "parsers": [
      "linux-oom",
      "port-conflict"
    ]
  }
}