{
  "version": 1,
  "meta": {
    "id": "euro_truck_simulator_2",
    "name": "Euro Truck Simulator 2 (ETS2)",
    "category": "steam_game",
    "author": "Maunting Studios",
    "description": "Euro Truck Simulator 2 Dedicated Server via SteamCMD (App-ID 1948160). Nativer Linux-Support. Konfiguration über server_config.sii."
  },
  "runtime": {
    "image": "ghcr.io/parkervcp/steamcmd:debian",
    "workdir": "/data",
    "user": "1000:1000",
    "env": {
      "HOME": "/data",
      "LD_LIBRARY_PATH": ".:./linux64:/usr/lib32:/usr/lib/x86_64-linux-gnu"
    },
    "startup": "./bin/linux_x64/eurotrucks2_server -server",
    "ensureDirs": [
      ".local/share/Euro Truck Simulator 2"
    ],
    "requiredFiles": [
      "bin/linux_x64/eurotrucks2_server"
    ],
    "configPatches": [
      {
        "type": "regex",
        "file": ".local/share/Euro Truck Simulator 2/server_config.sii",
        "regex": "(connection_server_port\\s*:\\s*)\\d+",
        "value": "\\g<1>{GAME_PORT}"
      },
      {
        "type": "regex",
        "file": ".local/share/Euro Truck Simulator 2/server_config.sii",
        "regex": "(connection_query_port\\s*:\\s*)\\d+",
        "value": "\\g<1>{QUERY_PORT}"
      }
    ],
    "startupCheckSeconds": 60.0
  },
  "ports": [
    { "name": "game", "protocol": "udp" },
    { "name": "query", "protocol": "udp" }
  ],
  "source": {
    "type": "steam",
    "steam": {
      "appId": "1948160",
      "platform": "linux",
      "compatibility": "native",
      "requiresLogin": false,
      "validate": false
    },
    "updateStrategy": "checkBased"
  },
  "mods": {
    "supportsMods": false,
    "supportsSteamWorkshop": false,
    "workshopAppId": null,
    "modInjection": "none",
    "modStartupArgumentFormat": null,
    "modListFilePath": null,
    "modListContent": "workshopIds",
    "postInstall": []
  },
  "health": {
    "process": {},
    "application": {
      "type": "source-query"
    }
  },
  "backup": {
    "includePaths": [
      ".local/share/Euro Truck Simulator 2/server_config.sii",
      ".local/share/Euro Truck Simulator 2/profiles"
    ]
  }
}
