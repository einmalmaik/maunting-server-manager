{
  "version": 1,
  "meta": {
    "id": "euro_truck_simulator_2",
    "name": "Euro Truck Simulator 2 (ETS2)",
    "category": "steam_game",
    "author": "Maunting Studios",
    "description": "Euro Truck Simulator 2 Dedicated Server via SteamCMD (App-ID 1948160). Nativer Linux-Support. Konfiguration \u00c3\u00bcber server_config.sii."
  },
  "runtime": {
    "image": "ghcr.io/parkervcp/steamcmd:debian",
    "workdir": "/data",
    "user": "1000:1000",
    "env": {
      "HOME": "/data",
      "LD_LIBRARY_PATH": ".:./linux64:/usr/lib32:/usr/lib/x86_64-linux-gnu"
    },
    "startup": "./bin/linux_x64/eurotrucks2_server -server",
    "ensureDirs": [
      ".local/share/Euro Truck Simulator 2"
    ],
    "requiredFiles": [
      "bin/linux_x64/eurotrucks2_server"
    ],
    "configPatches": [
      {
        "type": "regex",
        "file": ".local/share/Euro Truck Simulator 2/server_config.sii",
        "regex": "(connection_server_port\\s*:\\s*)\\d+",
        "value": "\\g<1>{GAME_PORT}"
      },
      {
        "type": "regex",
        "file": ".local/share/Euro Truck Simulator 2/server_config.sii",
        "regex": "(connection_query_port\\s*:\\s*)\\d+",
        "value": "\\g<1>{QUERY_PORT}"
      }
    ],
    "startupCheckSeconds": 60.0
  },
  "ports": [
    {
      "name": "game",
      "protocol": "udp"
    },
    {
      "name": "query",
      "protocol": "udp"
    }
  ],
  "source": {
    "type": "steam",
    "steam": {
      "appId": "1948160",
      "platform": "linux",
      "compatibility": "native",
      "requiresLogin": false,
      "validate": false
    },
    "updateStrategy": "checkBased"
  },
  "mods": {
    "supportsMods": false,
    "supportsSteamWorkshop": false,
    "workshopAppId": null,
    "modInjection": "none",
    "modStartupArgumentFormat": null,
    "modListFilePath": null,
    "modListContent": "workshopIds",
    "postInstall": []
  },
  "health": {
    "process": {},
    "application": {
      "type": "source-query",
      "port": "{{QUERY_PORT}}",
      "interval": "60s",
      "failure_threshold": 3
    },
    "startup": {
      "grace_period_seconds": 60,
      "success_patterns": [
        "Server has been started",
        "session successfully created"
      ],
      "failure_patterns": [
        "Address already in use",
        "Could not bind"
      ]
    }
  },
  "logs": {
    "sources": [
      ".local/share/Euro Truck Simulator 2/server.log.txt",
      "stdout"
    ],
    "redact": [
      "regex:password"
    ]
  },
  "diagnostics": {
    "parsers": [
      "linux-oom",
      "port-conflict"
    ]
  },
  "recovery": {
    "policies": [
      {
        "match": "process_not_running",
        "action": "restart"
      },
      {
        "match": "source_query_failed",
        "action": "restart"
      },
      {
        "match": "port-conflict",
        "action": "clear_declared_lock_files"
      },
      {
        "match": "linux-oom",
        "action": "graceful_restart"
      }
    ],
    "attempt_window_seconds": 600,
    "max_attempts": 3,
    "cooldown_seconds": 60
  },
  "backup": {
    "includePaths": [
      ".local/share/Euro Truck Simulator 2/server_config.sii",
      ".local/share/Euro Truck Simulator 2/profiles"
    ]
  }
}