{
  "version": 1,
  "meta": {
    "id": "icarus",
    "name": "Icarus",
    "category": "steam_game",
    "author": "Maunting Studios",
    "description": "Icarus Dedicated Server via SteamCMD (App-ID 2089390). Runs on Windows-binary via GE-Proton/Wine."
  },
  "runtime": {
    "image": "ghcr.io/parkervcp/yolks:wine_10",
    "workdir": "/home/container",
    "user": "1000:1000",
    "env": {
      "WINEDEBUG": "-all",
      "WINEESYNC": "1",
      "WINEFSYNC": "1"
    },
    "startup": "./IcarusServer.exe -Port={GAME_PORT} -QueryPort={QUERY_PORT} -Log",
    "ensureDirs": [
      "Icarus/Saved"
    ],
    "requiredFiles": [
      "IcarusServer.exe"
    ],
    "configPatches": [],
    "startupCheckSeconds": 90.0
  },
  "ports": [
    {
      "name": "game",
      "protocol": "udp"
    },
    {
      "name": "query",
      "protocol": "udp"
    }
  ],
  "source": {
    "type": "steam",
    "steam": {
      "appId": "2089390",
      "platform": "windows",
      "compatibility": "proton",
      "requiresLogin": false,
      "validate": false
    },
    "updateStrategy": "checkBased"
  },
  "mods": {
    "supportsMods": false,
    "supportsSteamWorkshop": false,
    "workshopAppId": null,
    "modInjection": "none",
    "modStartupArgumentFormat": null,
    "modListFilePath": null,
    "modListContent": "workshopIds",
    "postInstall": []
  },
  "health": {
    "process": {},
    "application": {
      "type": "source-query",
      "port": "{{QUERY_PORT}}",
      "interval": "60s",
      "failure_threshold": 3
    },
    "startup": {
      "grace_period_seconds": 120,
      "success_patterns": [
        "Server started successfully",
        "Waiting for players"
      ],
      "failure_patterns": [
        "Address already in use"
      ]
    }
  },
  "recovery": {
    "policies": [
      {
        "match": "process_not_running",
        "action": "restart"
      },
      {
        "match": "source_query_failed",
        "action": "restart"
      },
      {
        "match": "port-conflict",
        "action": "clear_declared_lock_files"
      },
      {
        "match": "linux-oom",
        "action": "graceful_restart"
      }
    ],
    "attempt_window_seconds": 600,
    "max_attempts": 3,
    "cooldown_seconds": 60
  },
  "backup": {
    "includePaths": [
      "Icarus/Saved"
    ]
  },
  "logs": {
    "sources": [
      "Icarus/Saved/Logs/Icarus.log",
      "stdout"
    ],
    "redact": [
      "regex:Password"
    ]
  },
  "diagnostics": {
    "parsers": [
      "linux-oom",
      "port-conflict"
    ]
  }
}