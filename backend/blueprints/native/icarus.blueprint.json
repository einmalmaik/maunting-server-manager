{
  "version": 1,
  "meta": {
    "id": "icarus",
    "name": "Icarus",
    "category": "steam_game",
    "author": "Maunting Studios",
    "description": "Icarus Dedicated Server via SteamCMD (App-ID 2089390). Runs on Windows-binary via GE-Proton/Wine."
  },
  "runtime": {
    "image": "ghcr.io/parkervcp/yolks:wine_10",
    "workdir": "/home/container",
    "user": "1000:1000",
    "env": {
      "WINEDEBUG": "-all",
      "WINEESYNC": "1",
      "WINEFSYNC": "1"
    },
    "startup": "./IcarusServer.exe -Port={GAME_PORT} -QueryPort={QUERY_PORT} -Log",
    "ensureDirs": [
      "Icarus/Saved"
    ],
    "requiredFiles": [
      "IcarusServer.exe"
    ],
    "configPatches": [],
    "startupCheckSeconds": 90.0
  },
  "ports": [
    { "name": "game", "protocol": "udp" },
    { "name": "query", "protocol": "udp" }
  ],
  "source": {
    "type": "steam",
    "steam": {
      "appId": "2089390",
      "platform": "windows",
      "compatibility": "proton",
      "requiresLogin": false,
      "validate": false
    },
    "updateStrategy": "checkBased"
  },
  "mods": {
    "supportsMods": false,
    "supportsSteamWorkshop": false,
    "workshopAppId": null,
    "modInjection": "none",
    "modStartupArgumentFormat": null,
    "modListFilePath": null,
    "modListContent": "workshopIds",
    "postInstall": []
  },
  "health": {
    "process": {},
    "application": {
      "type": "source-query"
    }
  },
  "backup": {
    "includePaths": [
      "Icarus/Saved"
    ]
  }
}
