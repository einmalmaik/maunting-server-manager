{
  "version": 1,
  "meta": {
    "id": "minecraft_sponge",
    "name": "Minecraft (SpongeVanilla)",
    "category": "non_steam_game",
    "author": "Maunting Studios",
    "description": "SpongeVanilla-Server via itzg/minecraft-server. Sponge-Plugin-Plattform auf Vanilla-Basis. Plugins in /data/mods (Sponge laedt aus diesem Ordner)."
  },
  "runtime": {
    "image": "itzg/minecraft-server:latest",
    "workdir": "/data",
    "env": {
      "EULA": "TRUE",
      "TYPE": "SPONGEVANILLA",
      "VERSION": "LATEST",
      "SERVER_PORT": "{GAME_PORT}",
      "ENABLE_RCON": "true",
      "RCON_PORT": "{RCON_PORT}"
    },
    "startup": "/start"
  },
  "ports": [
    {
      "name": "game",
      "protocol": "tcp"
    },
    {
      "name": "query",
      "protocol": "udp"
    },
    {
      "name": "rcon",
      "protocol": "tcp"
    }
  ],
  "source": {
    "type": "dockerOnly",
    "steam": null,
    "http": null
  },
  "mods": {
    "supportsMods": true,
    "supportsSteamWorkshop": false,
    "workshopAppId": null,
    "modInjection": "none",
    "modStartupArgumentFormat": null,
    "modListFilePath": null
  },
  "health": {
    "process": {},
    "application": {
      "type": "minecraft-status"
    }
  },
  "recovery": {
    "policies": [
      {
        "match": "process_not_running",
        "action": "restart"
      },
      {
        "match": "minecraft_status_failed",
        "action": "restart"
      },
      {
        "match": "minecraft_query_failed",
        "action": "restart"
      }
    ],
    "attempt_window_seconds": 600,
    "max_attempts": 3,
    "cooldown_seconds": 60
  }
}
