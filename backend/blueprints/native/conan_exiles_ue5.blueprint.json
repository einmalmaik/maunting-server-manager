{
  "version": 1,
  "meta": {
    "id": "conan_exiles_ue5",
    "name": "Conan Exiles (UE5)",
    "category": "steam_game",
    "author": "Maunting Studios",
    "description": "Conan Exiles Enhanced (UE5) Dedicated Server (App-ID 443030, Workshop 440900)."
  },
  "runtime": {
    "image": "ghcr.io/parkervcp/steamcmd:debian",
    "workdir": "/data",
    "user": "1000:1000",
    "env": {},
    "startup": "/bin/bash /data/ConanSandboxServer.sh -log -Port={GAME_PORT} -QueryPort={QUERY_PORT} -RconPort={RCON_PORT}",
    "configPatches": [
      {
        "type": "ini",
        "file": "ConanSandbox/Saved/Config/LinuxServer/Engine.ini",
        "section": "URL",
        "key": "Port",
        "value": "{GAME_PORT}"
      },
      {
        "type": "ini",
        "file": "ConanSandbox/Saved/Config/LinuxServer/Engine.ini",
        "section": "OnlineSubsystemNull",
        "key": "GameServerQueryPort",
        "value": "{QUERY_PORT}"
      },
      {
        "type": "ini",
        "file": "ConanSandbox/Saved/Config/LinuxServer/Game.ini",
        "section": "RconPlugin",
        "key": "RconPort",
        "value": "{RCON_PORT}"
      },
      {
        "type": "ini",
        "file": "ConanSandbox/Saved/Config/LinuxServer/Game.ini",
        "section": "RconPlugin",
        "key": "RconEnabled",
        "value": "True"
      },
      {
        "type": "ini",
        "file": "ConanSandbox/Saved/Config/LinuxServer/ServerSettings.ini",
        "section": "ServerSettings",
        "key": "ServerModList",
        "value": "modlist.txt"
      }
    ]
  },
  "ports": [
    {
      "name": "game",
      "protocol": "udp"
    },
    {
      "name": "query",
      "protocol": "udp"
    },
    {
      "name": "rcon",
      "protocol": "tcp"
    }
  ],
  "source": {
    "type": "steam",
    "steam": {
      "appId": "443030",
      "platform": "linux",
      "compatibility": "native",
      "validate": false
    },
    "updateStrategy": "checkBased"
  },
  "mods": {
    "supportsMods": true,
    "supportsSteamWorkshop": true,
    "workshopAppId": "440900",
    "filterTags": [
      "Enhanced"
    ],
    "modInjection": "file",
    "modStartupArgumentFormat": null,
    "modListFilePath": "ConanSandbox/Mods/modlist.txt",
    "modListContent": "postInstallTargetBasenames",
    "postInstall": [
      {
        "operation": "copy",
        "source": "steamapps/workshop/content/{WORKSHOP_APP_ID}/{WORKSHOP_ID}/**/*.pak",
        "target": "ConanSandbox/Mods/{BASENAME}",
        "required": true
      }
    ]
  },
  "health": {
    "process": {},
    "application": {
      "type": "source-query",
      "port": "{{QUERY_PORT}}",
      "interval": "60s",
      "failure_threshold": 3
    },
    "startup": {
      "grace_period_seconds": 120,
      "success_patterns": [
        "Server waiting for players",
        "Server open for play"
      ],
      "failure_patterns": [
        "Address already in use",
        "Could not bind"
      ]
    }
  },
  "logs": {
    "sources": [
      "ConanSandbox/Saved/Logs/ConanSandbox.log",
      "stdout"
    ],
    "redact": [
      "api_key",
      "discord_token"
    ]
  },
  "diagnostics": {
    "parsers": [
      "linux-oom",
      "port-conflict"
    ]
  },
  "recovery": {
    "policies": [
      {
        "match": "process_not_running",
        "action": "restart"
      },
      {
        "match": "source_query_failed",
        "action": "restart"
      },
      {
        "match": "port-conflict",
        "action": "clear_declared_lock_files"
      },
      {
        "match": "linux-oom",
        "action": "graceful_restart"
      }
    ],
    "attempt_window_seconds": 600,
    "max_attempts": 3,
    "cooldown_seconds": 60
  },
  "backup": {
    "includePaths": [
      "ConanSandbox/Saved/Config",
      "ConanSandbox/Saved/SaveGames",
      "ConanSandbox/Saved/game.db"
    ]
  }
}
