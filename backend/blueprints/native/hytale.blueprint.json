{
  "version": 1,
  "meta": {
    "id": "hytale",
    "name": "Hytale (Dedicated)",
    "category": "non_steam_game",
    "author": "Maunting Studios",
    "description": "Hytale Dedicated Server via offiziellem Hytale Linux-Downloader. Beim ersten Start zeigt die Console den Hytale-OAuth-Link an; danach lädt der Downloader die Serverdateien in das Server-Verzeichnis."
  },
  "runtime": {
    "image": "ghcr.io/natroutter/egg-hytale:latest",
    "workdir": "/home/container",
    "env": {
      "STARTUP": "./start.sh",
      "SERVER_PORT": "{GAME_PORT}",
      "AUTH_MODE": "AUTHENTICATED",
      "AUTOMATIC_UPDATE": "1",
      "PATCHLINE": "release",
      "ASSET_PACK": "Assets.zip",
      "DISABLE_SENTRY": "1",
      "ACCEPT_EARLY_PLUGINS": "0",
      "LEVERAGE_AHEAD_OF_TIME_CACHE": "1",
      "USE_PERSISTENT_AUTHENTICATION": "DISABLED",
      "MEMORY_OVERHEAD": "0"
    },
    "startup": "/start.sh"
  },
  "ports": [
    { "name": "game", "protocol": "udp" }
  ],
  "source": {
    "type": "http",
    "http": {
      "url": "https://downloader.hytale.com/hytale-downloader.zip",
      "archiveType": "zip"
    }
  },
  "mods": {
    "supportsMods": true,
    "supportsSteamWorkshop": false,
    "workshopAppId": null,
    "modInjection": "none",
    "modStartupArgumentFormat": null,
    "modListFilePath": null
  }
}
