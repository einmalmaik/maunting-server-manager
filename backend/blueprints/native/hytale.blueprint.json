{
  "version": 1,
  "meta": {
    "id": "hytale",
    "name": "Hytale (Dedicated)",
    "category": "non_steam_game",
    "author": "Maunting Studios",
    "description": "Hytale Dedicated Server via offiziellem Hytale Linux-Downloader. Beim ersten Start zeigt die Console den Hytale-OAuth-Link an; danach l\u00c3\u00a4dt der Downloader die Serverdateien in das Server-Verzeichnis."
  },
  "runtime": {
    "image": "ghcr.io/natroutter/egg-hytale:latest",
    "workdir": "/home/container",
    "env": {
      "STARTUP": "./start.sh",
      "SERVER_PORT": "{GAME_PORT}",
      "AUTH_MODE": "AUTHENTICATED",
      "AUTOMATIC_UPDATE": "1",
      "PATCHLINE": "release",
      "ASSET_PACK": "Assets.zip",
      "JAVA_TOOL_OPTIONS": "-Dio.netty.native.workdir=/home/container -Djava.io.tmpdir=/home/container",
      "DISABLE_SENTRY": "1",
      "ACCEPT_EARLY_PLUGINS": "0",
      "LEVERAGE_AHEAD_OF_TIME_CACHE": "1",
      "USE_PERSISTENT_AUTHENTICATION": "DISABLED",
      "MEMORY_OVERHEAD": "0"
    },
    "startup": "/entrypoint.sh"
  },
  "ports": [
    {
      "name": "game",
      "protocol": "udp"
    }
  ],
  "source": {
    "type": "http",
    "http": {
      "url": "https://downloader.hytale.com/hytale-downloader.zip",
      "archiveType": "zip"
    }
  },
  "mods": {
    "supportsMods": true,
    "supportsSteamWorkshop": false,
    "workshopAppId": null,
    "modInjection": "none",
    "modStartupArgumentFormat": null,
    "modListFilePath": null
  },
  "health": {
    "process": {},
    "application": {
      "type": "source-query",
      "port": "{{QUERY_PORT}}",
      "interval": "60s",
      "failure_threshold": 3
    },
    "startup": {
      "grace_period_seconds": 120,
      "success_patterns": [
        "Server started",
        "Done \\("
      ],
      "failure_patterns": [
        "FAILED TO BIND TO PORT"
      ]
    }
  },
  "recovery": {
    "policies": [
      {
        "match": "process_not_running",
        "action": "restart"
      },
      {
        "match": "source_query_failed",
        "action": "restart"
      },
      {
        "match": "port-conflict",
        "action": "clear_declared_lock_files"
      },
      {
        "match": "linux-oom",
        "action": "graceful_restart"
      }
    ],
    "attempt_window_seconds": 600,
    "max_attempts": 3,
    "cooldown_seconds": 60
  },
  "logs": {
    "sources": [
      "logs/latest.log",
      "stdout"
    ],
    "redact": [
      "regex:rcon\\.password",
      "regex:password"
    ]
  },
  "diagnostics": {
    "parsers": [
      "linux-oom",
      "port-conflict"
    ]
  }
}