# Maunting Server Manager — Umgebungsvariablen
# Wird automatisch durch install.sh generiert. Manuelle Änderungen auf eigene Gefahr.

# ── App ──
MSM_APP_NAME="Maunting Server Manager"
MSM_DEBUG=false

# ── Datenbank ──
# SQLite (einfach, Single-Server):
MSM_DATABASE_URL="sqlite:///./msm.db"
MSM_DATABASE_URL_ASYNC="sqlite+aiosqlite:///./msm.db"
# PostgreSQL (empfohlen für Produktion):
# MSM_DATABASE_URL="postgresql+psycopg2://msm:PASSWORT@localhost:5432/msm"
# MSM_DATABASE_URL_ASYNC="postgresql+asyncpg://msm:PASSWORT@localhost:5432/msm"

# ── Sicherheit (WICHTIG: SECRET_KEY wird bei Installation automatisch generiert) ──
MSM_SECRET_KEY="{{AUTO_GENERATED}}"
MSM_ALGORITHM="HS256"
MSM_ACCESS_TOKEN_EXPIRE_MINUTES=15
MSM_REFRESH_TOKEN_EXPIRE_DAYS=30
MSM_CSRF_TOKEN_EXPIRE_MINUTES=1440

# ── Email ──
# Option 1: Resend (resend.com) — einfach, empfohlen
MSM_EMAIL_PROVIDER="resend"
MSM_RESEND_API_KEY=""
MSM_SMTP_FROM="noreply@mauntingstudios.de"

# Option 2: SMTP (eigener Server, Strato, Gmail, etc.)
# MSM_EMAIL_PROVIDER="smtp"
# MSM_SMTP_HOST=""
# MSM_SMTP_PORT=587
# MSM_SMTP_USER=""
# MSM_SMTP_PASSWORD=""
# MSM_SMTP_TLS=true
# MSM_SMTP_FROM="noreply@mauntingstudios.de"

# ── Panel ──
MSM_PANEL_URL="https://{{DOMAIN}}"
MSM_SETUP_COMPLETED_FILE="/opt/msm/.setup_completed"

# ── Server-Verzeichnis ──
# Produktion (install.sh): /opt/msm/servers
# Dev/WSL ohne sudo: ./servers
MSM_SERVERS_DIR="/opt/msm/servers"

# ── Rootless Docker ──
# Produktion (install.sh): unix:///run/user/<msm_uid>/docker.sock
# Leer lassen = Backend berechnet den Rootless-Socket des laufenden Users.
MSM_DOCKER_HOST=""

# ── Steam ──
MSM_STEAMCMD_PATH="/usr/games/steamcmd"
MSM_STEAM_API_KEY=""

# ── Rate Limiting (optional: Redis für Multi-Instance) ──
# Leer lassen = in-memory (funktioniert für Single-Server)
# Format: redis://localhost:6379
REDIS_URL=""

# ── Auto-Update (GitHub Releases) ──
# false = nur manuelles Update via: sudo bash /opt/msm/update.sh
# true  = systemd-Timer prüft alle 24h automatisch
MSM_GITHUB_OWNER="einmalmaik"
MSM_GITHUB_REPO="maunting-server-manager"
MSM_AUTO_UPDATE=false
MSM_AUTO_UPDATE_INTERVAL_HOURS=24
