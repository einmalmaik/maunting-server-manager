# Maunting Server Manager — Backend Umgebungsvariablen
# Kopieren nach backend/.env und anpassen.
# install.sh kann Produktionswerte generieren. Keine echten Secrets committen.
# Prefix: MSM_ (siehe backend/config.py Settings)

# ── App ──
MSM_APP_NAME="Maunting Server Manager"
MSM_DEBUG=false

# ── Datenbank ──
# PostgreSQL ist die einzige unterstützte Panel-Runtime-Datenbank.
MSM_DATABASE_URL="postgresql+psycopg2://msm:PASSWORT@localhost:5432/msm"
MSM_DATABASE_URL_ASYNC="postgresql+asyncpg://msm:PASSWORT@localhost:5432/msm"

# ── Sicherheit ──
# Pflicht in Produktion: starker Wert >= 32 Zeichen (kein Default-Placeholder).
MSM_SECRET_KEY="{{AUTO_GENERATED}}"
MSM_ALGORITHM="HS256"
MSM_ACCESS_TOKEN_EXPIRE_MINUTES=15
MSM_REFRESH_TOKEN_EXPIRE_DAYS=30
MSM_CSRF_TOKEN_EXPIRE_MINUTES=1440

# ── DIS Sidecar (Krypto: AES-GCM, Argon2id, TOTP — Panel hat keine eigene Crypto) ──
MSM_DIS_SIDECAR_URL="http://127.0.0.1:9100"
MSM_DIS_SIDECAR_TOKEN="{{AUTO_GENERATED}}"
MSM_DIS_SALT="{{AUTO_GENERATED}}"

# ── Email ──
# resend | smtp
MSM_EMAIL_PROVIDER="resend"
MSM_RESEND_API_KEY=""
MSM_SMTP_HOST=""
MSM_SMTP_PORT=587
MSM_SMTP_USER=""
MSM_SMTP_PASSWORD=""
MSM_SMTP_TLS=true
MSM_SMTP_FROM="noreply@mauntingstudios.de"

# ── Panel / Frontend-URL ──
# OAuth redirect_uri, E-Mail-Links, CORS-Basis. Produktion: HTTPS-Domain des SPA.
MSM_PANEL_URL="https://{{DOMAIN}}"
MSM_SETUP_COMPLETED_FILE="/opt/msm/.setup_completed"
# Absolute Logo-URL in E-Mails (leer = MSM_PANEL_URL + /logo.png)
MSM_LOGO_URL=""

# ── Cookies ──
# Optionaler Domain-Override (z. B. .example.com). Leer = aus MSM_PANEL_URL ableiten; localhost = host-only.
MSM_COOKIE_DOMAIN=""
# true = SameSite=None + Secure (FE und API auf verschiedenen Sites, z. B. Vercel + API-Host).
# false = SameSite=Lax/Strict (Single-Host, Reverse-Proxy, Vite-Proxy).
MSM_COOKIE_CROSS_SITE=false

# ── Frontend-Entkopplung (Phase 4 / Vercel) ──
# Zusaetzliche CORS-Origins, Komma-separiert. MSM_PANEL_URL ist immer erlaubt.
# Bei debug=true werden localhost:3000 / :5173 automatisch ergaenzt.
MSM_CORS_ALLOWED_ORIGINS=""
# Backend mountet gebautes SPA unter /opt/msm/frontend/dist. false = reines API-Backend.
MSM_SERVE_FRONTEND=true

# ── Pfade ──
# Produktion: /opt/msm/servers  |  Dev oft: ./servers
MSM_SERVERS_DIR="/opt/msm/servers"
MSM_LOCAL_AGENT_ENV_FILE="/opt/msm/msm-agent/.env"
MSM_PANEL_CONFIG_DIR="/opt/msm"
MSM_PANEL_BACKUP_DIR="/opt/msm/backups/panel"
MSM_BLUEPRINTS_DIR="/opt/msm/blueprints/community"

# ── Docker ──
# Leer = Rootless-Default des laufenden Users. Prod: unix:///run/user/<uid>/docker.sock
MSM_DOCKER_HOST=""

# ── Managed PostgreSQL (Game-Server-DBs) ──
MSM_MANAGED_POSTGRES_IMAGE="postgres:17-alpine"
MSM_MANAGED_POSTGRES_CONTAINER_NAME="msm-postgres"
MSM_MANAGED_POSTGRES_NETWORK="msm-internal"
MSM_MANAGED_POSTGRES_HOST="127.0.0.1"
MSM_MANAGED_POSTGRES_PORT=15432
MSM_MANAGED_POSTGRES_DATA_DIR="/opt/msm/postgres"
MSM_MANAGED_POSTGRES_STATEMENT_TIMEOUT_MS=5000
MSM_MANAGED_POSTGRES_ROW_LIMIT=500

# ── Steam / GitHub ──
MSM_STEAMCMD_PATH="/usr/games/steamcmd"
MSM_STEAM_API_KEY=""
# Optional: private GitHub-Repos (Blueprint source.type=github)
MSM_GITHUB_CLONE_TOKEN=""

# ── Rate Limiting ──
# Leer = in-memory. Multi-Instance: redis://localhost:6379
MSM_REDIS_URL=""

# ── Auto-Update (GitHub Releases) ──
MSM_GITHUB_OWNER="einmalmaik"
MSM_GITHUB_REPO="maunting-server-manager"
MSM_AUTO_UPDATE=false
MSM_AUTO_UPDATE_INTERVAL_HOURS=24
