# Maunting Server Manager — Backend-Konfiguration
#
# Installation:
#   cp backend/.env.example backend/.env
#   chmod 600 backend/.env
#
# Empfohlen: install.sh verwenden. Der Installer erzeugt PostgreSQL-Zugang,
# Secret-Key, DIS-Salt und DIS-Token automatisch und schreibt backend/.env.
# Niemals eine echte .env oder darin enthaltene Secrets committen.
#
# Status-Legende:
#   AUTOMATISCH = install.sh erzeugt/setzt den Wert; normalerweise nicht anfassen.
#   PFLICHT     = bei manueller Installation selbst korrekt setzen.
#   OPTIONAL    = nur setzen, wenn die beschriebene Funktion verwendet wird.
#   STANDARD    = sicherer Standard; nur mit konkretem Grund ändern.
#   ERWEITERT   = Betriebs-/Tuningwert für erfahrene Betreiber.

# ── Anwendung ─────────────────────────────────────────────────────────────

# Status: STANDARD
# Zweck: Anzeigename des Panels. Rein kosmetisch, kein Hostname und keine URL.
# Herkunft: Mitgelieferter Standard; für Branding optional ändern.
MSM_APP_NAME="Maunting Server Manager"

# Status: STANDARD
# Zweck: Aktiviert Entwicklungsdiagnosen und lokale CORS-Ausnahmen.
# Herkunft: In Produktion immer false lassen; true nur lokal zur Fehlersuche.
MSM_DEBUG=false

# ── Panel-Datenbank ───────────────────────────────────────────────────────

# Status: AUTOMATISCH / bei manueller Installation PFLICHT
# Zweck: Synchrone SQLAlchemy-Verbindung zur eigenen Panel-Datenbank.
# Herkunft: install.sh erstellt DB/User/Passwort. Manuell dieselbe PostgreSQL-DB
# in beiden URLs verwenden und Sonderzeichen im Passwort URL-kodieren.
# Format: postgresql+psycopg2://BENUTZER:PASSWORT@HOST:5432/DATENBANK
MSM_DATABASE_URL="postgresql+psycopg2://msm:PASSWORT@localhost:5432/msm"

# Status: AUTOMATISCH / bei manueller Installation PFLICHT
# Zweck: Asynchrone Verbindung zu exakt derselben Panel-Datenbank wie oben.
# Herkunft: Gleiche Zugangsdaten; nur der Treiber ist asyncpg statt psycopg2.
# Format: postgresql+asyncpg://BENUTZER:PASSWORT@HOST:5432/DATENBANK
MSM_DATABASE_URL_ASYNC="postgresql+asyncpg://msm:PASSWORT@localhost:5432/msm"

# ── Session- und CSRF-Sicherheit ──────────────────────────────────────────

# Status: AUTOMATISCH / bei manueller Installation PFLICHT
# Zweck: Signiert Sessions/JWTs. Verlust meldet Benutzer ab; Änderung invalidiert Tokens.
# Herkunft: install.sh erzeugt ihn. Manuell: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# Mindestanforderung: zufällig, geheim und mindestens 32 Zeichen.
MSM_SECRET_KEY="{{AUTO_GENERATED}}"

# Status: STANDARD
# Zweck: Signaturalgorithmus der Panel-Tokens.
# Herkunft: Projektstandard; nicht ohne Code-/Migrationsprüfung ändern.
MSM_ALGORITHM="HS256"

# Status: ERWEITERT
# Zweck: Lebensdauer eines Access-Tokens in Minuten.
# Herkunft: Sicherer Projektstandard; kürzer = sicherer, aber mehr Refreshes.
MSM_ACCESS_TOKEN_EXPIRE_MINUTES=15

# Status: ERWEITERT
# Zweck: Maximale Lebensdauer eines Refresh-Tokens in Tagen.
# Herkunft: Projektstandard; Änderung wirkt auf neu ausgestellte Sessions.
MSM_REFRESH_TOKEN_EXPIRE_DAYS=30

# Status: ERWEITERT
# Zweck: Lebensdauer des CSRF-Tokens in Minuten.
# Herkunft: 1440 Minuten = 24 Stunden; normalerweise nicht ändern.
MSM_CSRF_TOKEN_EXPIRE_MINUTES=1440

# ── DIS Sidecar ───────────────────────────────────────────────────────────

# Status: AUTOMATISCH / bei manueller Installation PFLICHT
# Zweck: Interne URL des lokalen Kryptografie-Sidecars; niemals öffentlich routen.
# Herkunft: install.sh startet DIS auf Loopback-Port 9100.
MSM_DIS_SIDECAR_URL="http://127.0.0.1:9100"

# Status: AUTOMATISCH / bei manueller Installation PFLICHT
# Zweck: Bearer-Token zwischen Backend und DIS. Muss in beiden .env-Dateien identisch sein.
# Herkunft: install.sh erzeugt ihn. Manuell: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MSM_DIS_SIDECAR_TOKEN="{{AUTO_GENERATED}}"

# Status: AUTOMATISCH / bei manueller Installation PFLICHT
# Zweck: Salt für die DIS-Schlüsselableitung. Nach Verschlüsselung erster Daten nie ändern.
# Herkunft: install.sh erzeugt ihn. Manuell: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Achtung: Verlust oder Änderung macht bereits verschlüsselte Daten unlesbar.
MSM_DIS_SALT="{{AUTO_GENERATED}}"

# ── E-Mail ────────────────────────────────────────────────────────────────

# Status: OPTIONAL
# Zweck: Wählt den Versandweg für Verifizierung, Passwort-Reset und Hinweise.
# Herkunft: "resend" für Resend oder "smtp" für einen eigenen Mailanbieter.
# Ohne vollständig konfigurierte Zugangsdaten bleibt E-Mail-Versand deaktiviert.
MSM_EMAIL_PROVIDER="resend"

# Status: OPTIONAL (nur bei MSM_EMAIL_PROVIDER=resend)
# Zweck: Geheimer Resend-Schlüssel zum Senden von E-Mails.
# Herkunft: Resend Dashboard → API Keys; möglichst "Sending access" verwenden.
# Offizielle Anleitung: https://resend.com/docs/dashboard/api-keys/introduction
# Alternativ im Panel unter Einstellungen hinterlegen. Niemals im Frontend setzen.
MSM_RESEND_API_KEY=""

# Status: OPTIONAL (nur bei MSM_EMAIL_PROVIDER=smtp)
# Zweck: Hostname des SMTP-Servers, z. B. smtp.example.com.
# Herkunft: Dokumentation/Zugangsdaten des eigenen E-Mail-Anbieters.
MSM_SMTP_HOST=""

# Status: OPTIONAL (nur bei SMTP)
# Zweck: SMTP-Port; üblich sind 587 mit STARTTLS oder anbieterspezifische Werte.
# Herkunft: Dokumentation des E-Mail-Anbieters.
MSM_SMTP_PORT=587

# Status: OPTIONAL (nur bei SMTP)
# Zweck: SMTP-Benutzername.
# Herkunft: E-Mail-Anbieter; oft die vollständige Absenderadresse.
MSM_SMTP_USER=""

# Status: OPTIONAL (nur bei SMTP)
# Zweck: SMTP-Passwort oder anbieterspezifisches App-Passwort.
# Herkunft: E-Mail-Anbieter. Niemals das normale Kontopasswort verwenden, wenn
# der Anbieter eigene App-Passwörter unterstützt.
MSM_SMTP_PASSWORD=""

# Status: STANDARD (nur bei SMTP)
# Zweck: Erzwingt verschlüsselte SMTP-Kommunikation.
# Herkunft: true lassen; false nur in einem bewusst isolierten Testnetz.
MSM_SMTP_TLS=true

# Status: OPTIONAL (bei aktiviertem E-Mail-Versand PFLICHT)
# Zweck: Sichtbare Absenderadresse.
# Herkunft: Eigene, beim E-Mail-Anbieter freigeschaltete/verifizierte Domain.
MSM_SMTP_FROM="noreply@example.com"

# ── Öffentliche Panel-Adresse ─────────────────────────────────────────────

# Status: AUTOMATISCH / bei manueller Installation PFLICHT
# Zweck: Öffentliche Basis-URL für OAuth-Callbacks, E-Mail-Links und CORS.
# Herkunft: Eigene HTTPS-Domain, über die Benutzer das Panel öffnen.
# Format: Origin ohne abschließenden Slash und ohne Pfad, z. B. https://panel.example.com
MSM_PANEL_URL="https://panel.example.com"

# Status: AUTOMATISCH
# Zweck: Markerdatei des Setup-Assistenten.
# Herkunft: install.sh; nur bei abweichendem Installationsverzeichnis ändern.
MSM_SETUP_COMPLETED_FILE="/opt/msm/.setup_completed"

# Status: OPTIONAL
# Zweck: Absolute Logo-URL in E-Mails.
# Herkunft: Eigene öffentlich erreichbare HTTPS-Datei; leer nutzt MSM_PANEL_URL + /logo.png.
MSM_LOGO_URL=""

# ── Cookies und getrenntes Frontend ──────────────────────────────────────

# Status: OPTIONAL
# Zweck: Gemeinsame Cookie-Domain für Subdomains.
# Herkunft: Eigene Domain. Leer = automatisch/host-only; Beispiel: .example.com
# Für Single-Host, localhost oder dieselbe Origin leer lassen.
MSM_COOKIE_DOMAIN=""

# Status: STANDARD
# Zweck: Erlaubt Session-Cookies zwischen wirklich verschiedenen Sites.
# Herkunft: false bei Single-Host/Reverse-Proxy. Nur bei getrennten HTTPS-Sites
# (z. B. Vercel-Frontend + API-Domain) auf true setzen; erfordert Secure-Cookies.
MSM_COOKIE_CROSS_SITE=false

# Status: OPTIONAL
# Zweck: Zusätzliche erlaubte Frontend-Origins für Browser-Anfragen.
# Herkunft: Exakte HTTPS-Origins des getrennten Frontends, komma-separiert,
# ohne Pfad und möglichst ohne abschließenden Slash.
# Beispiel: https://panel.vercel.app,https://admin.example.com
MSM_CORS_ALLOWED_ORIGINS=""

# Status: STANDARD
# Zweck: true liefert das gebaute React-Frontend direkt über das Backend aus.
# Herkunft: true für normale Installation; false für Vercel/separates Frontend.
MSM_SERVE_FRONTEND=true

# ── Lokale Pfade ─────────────────────────────────────────────────────────

# Status: AUTOMATISCH
# Zweck: Oberverzeichnis aller Gameserver-Dateien auf dem lokalen Panel-Node.
# Herkunft: install.sh; Pfad muss dem msm-Benutzer gehören und ausreichend Platz haben.
MSM_SERVERS_DIR="/opt/msm/servers"

# Status: AUTOMATISCH
# Zweck: Datei, aus der eine einmalige Migration den lokalen Agent-Token liest.
# Herkunft: install.sh; normalerweise nicht ändern.
MSM_LOCAL_AGENT_ENV_FILE="/opt/msm/msm-agent/.env"

# Status: AUTOMATISCH / bei Backend-only-Installation PFLICHT
# Zweck: Legt fest, ob auf diesem Control-Plane-Host zusätzlich ein lokaler
# Agent mit Rootless Docker betrieben wird.
# Herkunft: install.sh setzt true bei All-in-one und false bei Backend-only.
# Bei false muss ein aus einer Sicherung übernommener lokaler Node zuerst vom
# Migrationsassistenten als verifizierter Remote-Node registriert werden.
MSM_LOCAL_AGENT_ENABLED=true

# Status: OPTIONAL (nur Legacy-Migration)
# Zweck: Einmaliger direkter Token-Override, falls eine alte Installation keine
# lesbare lokale Agent-.env besitzt.
# Herkunft: Bestehender MSM_AGENT_TOKEN des lokalen Agents. Bei Neuinstallationen
# und normalem Multi-Node-Enrollment leer lassen; bevorzugt wird die Datei oben.
MSM_LOCAL_AGENT_TOKEN=""

# Status: AUTOMATISCH
# Zweck: Basisverzeichnis der Konfigurationsdateien für Panel-Backups.
# Herkunft: Installationsverzeichnis von MSM.
MSM_PANEL_CONFIG_DIR="/opt/msm"

# Status: AUTOMATISCH
# Zweck: Lokales Zielverzeichnis für Panel-Backups.
# Herkunft: install.sh; für andere Datenträger darf ein absoluter Pfad gesetzt werden.
MSM_PANEL_BACKUP_DIR="/opt/msm/backups/panel"

# Status: AUTOMATISCH
# Zweck: Verzeichnis für importierte Community-Blueprints.
# Herkunft: install.sh; native Blueprints bleiben Bestandteil des Repositorys.
MSM_BLUEPRINTS_DIR="/opt/msm/blueprints/community"

# ── Docker ────────────────────────────────────────────────────────────────

# Status: AUTOMATISCH / ERWEITERT
# Zweck: Docker-Socket des rootless msm-Benutzers.
# Herkunft: install.sh ermittelt unix:///run/user/<UID>/docker.sock.
# Leer = Anwendung ermittelt den Rootless-Standard. Niemals auf einen fremden
# oder öffentlich erreichbaren Docker-Daemon zeigen lassen.
MSM_DOCKER_HOST=""

# ── Verwaltetes PostgreSQL für Gameserver-Datenbanken ────────────────────
# Diese Werte beschreiben den Standard für den lokalen Node. Jeder Remote-Node
# hat seine eigene Agent-.env und damit seinen eigenen PostgreSQL-Container.
# Datenbankpasswörter stehen absichtlich nicht in .env; das Panel überträgt sie
# nur für die jeweilige Operation an den Agent.

# Status: STANDARD
# Zweck: Offizielles PostgreSQL-Container-Image.
# Herkunft: Projektstandard; nur nach getesteter Upgrade-/Migrationsplanung ändern.
MSM_MANAGED_POSTGRES_IMAGE="postgres:17-alpine"

# Status: STANDARD
# Zweck: Fester Container-/DNS-Name für die servereigenen Datenbanken dieses Nodes.
# Herkunft: Projektstandard; auf verschiedenen physischen Nodes darf er gleich sein.
MSM_MANAGED_POSTGRES_CONTAINER_NAME="msm-postgres"

# Status: STANDARD
# Zweck: Internes Docker-Netz für Gameserver → PostgreSQL.
# Herkunft: Wird automatisch angelegt; nicht öffentlich exponieren.
MSM_MANAGED_POSTGRES_NETWORK="msm-internal"

# Status: STANDARD (Sicherheitsgrenze)
# Zweck: Host-Bind-Adresse für Agent-interne Verwaltungszugriffe.
# Herkunft: Muss 127.0.0.1 bleiben; 0.0.0.0 wird vom Agent abgelehnt.
MSM_MANAGED_POSTGRES_HOST="127.0.0.1"

# Status: ERWEITERT
# Zweck: Loopback-Port des verwalteten PostgreSQL auf diesem physischen Node.
# Herkunft: 15432 ist Standard; nur bei lokaler Portkollision ändern.
MSM_MANAGED_POSTGRES_PORT=15432

# Status: AUTOMATISCH
# Zweck: Persistenter PostgreSQL-Datenpfad dieses Nodes.
# Herkunft: install.sh; niemals zwischen Nodes über ein gemeinsames Verzeichnis teilen.
MSM_MANAGED_POSTGRES_DATA_DIR="/opt/msm/postgres"

# Status: ERWEITERT
# Zweck: Maximale Laufzeit frei eingegebener SQL-Anweisungen in Millisekunden.
# Herkunft: Sicherheitsstandard 5000 ms; Erhöhung vergrößert DoS-/Last-Risiko.
MSM_MANAGED_POSTGRES_STATEMENT_TIMEOUT_MS=5000

# Status: ERWEITERT
# Zweck: Maximale Zeilenanzahl einer SQL-Ergebnisansicht im Panel.
# Herkunft: Sicherheits-/Speicherstandard; normalerweise nicht erhöhen.
MSM_MANAGED_POSTGRES_ROW_LIMIT=500

# ── Steam und GitHub ─────────────────────────────────────────────────────

# Status: STANDARD / Kompatibilität
# Zweck: Legacy-Pfad für lokale Tests; Produktion nutzt das SteamCMD-Tool-Image.
# Herkunft: install.sh bzw. Distribution. Normalerweise nicht ändern.
MSM_STEAMCMD_PATH="/usr/games/steamcmd"

# Status: OPTIONAL
# Zweck: Genauere Steam-Workshop-Metadaten und Update-Zeitpunkte.
# Herkunft: Steam Web API, https://steamcommunity.com/dev/apikey
# Alternativ sicher im Panel unter Einstellungen hinterlegen. Nicht erforderlich
# für anonyme SteamCMD-Downloads; loginpflichtige Spiele nutzen den Steam-Account im Panel.
MSM_STEAM_API_KEY=""

# Status: OPTIONAL
# Zweck: Klonen privater GitHub-Blueprint-Repositories über HTTPS.
# Herkunft: Fine-grained Personal Access Token für genau die benötigten Repositories
# mit minimalem Lesezugriff auf Repository-Inhalte.
# Offizielle Anleitung: https://docs.github.com/en/authentication/keeping-your-account-and-data-secure/managing-your-personal-access-tokens
# Für öffentliche Repositories leer lassen.
MSM_GITHUB_CLONE_TOKEN=""

# ── Rate-Limiting ────────────────────────────────────────────────────────

# Status: OPTIONAL
# Zweck: Gemeinsamer Rate-Limit-Speicher bei mehreren Backend-Instanzen.
# Herkunft: Eigener Redis-Dienst; Format z. B. redis://127.0.0.1:6379/0
# Leer = In-Memory-Limiter, ausreichend für genau eine Backend-Instanz.
MSM_REDIS_URL=""

# ── MSM-Auto-Update ──────────────────────────────────────────────────────

# Status: STANDARD
# Zweck: GitHub-Organisation/-Benutzer, aus dessen Releases Updates gelesen werden.
# Herkunft: Offizielles MSM-Repository; bei Forks bewusst auf den eigenen Owner ändern.
MSM_GITHUB_OWNER="einmalmaik"

# Status: STANDARD
# Zweck: GitHub-Repositoryname für Release-Updates.
# Herkunft: Offizielles MSM-Repository; bei Forks bewusst anpassen.
MSM_GITHUB_REPO="maunting-server-manager"

# Status: OPTIONAL
# Zweck: Aktiviert automatische Installation neuer GitHub-Releases per systemd-Timer.
# Herkunft: false ist der sichere Standard; true nur mit getesteter Backup-/Rollback-Strategie.
MSM_AUTO_UPDATE=false

# Status: ERWEITERT
# Zweck: Abstand zwischen Release-Prüfungen in Stunden.
# Herkunft: 24 Stunden ist der Projektstandard; wirkt nur bei MSM_AUTO_UPDATE=true.
MSM_AUTO_UPDATE_INTERVAL_HOURS=24

# ── Bewusst nicht als Produktionskonfiguration gedacht ───────────────────
# MSM_TESTING und MSM_SQLITE_MIGRATION sind ausschließlich interne Test- bzw.
# Einmal-Migrationsschalter. In einer normalen .env niemals setzen.
# S3-/MinIO-Zugangsdaten und Backup-Verschlüsselung werden im Panel verwaltet,
# DIS-verschlüsselt gespeichert und absichtlich nicht in diese Datei geschrieben.
