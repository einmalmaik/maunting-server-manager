# Production runtime data (when the git working tree root on the server is /opt/msm or similar)
# These MUST be protected so that `git clean -fd` (even on prod deploys) does not delete servers, DBs, logs or community blueprints.
# Note: git clean -fd by default respects .gitignore and will NOT remove these.
/servers/
/backups/
/blueprints/
/.setup_completed
*.db
*.sqlite
*.sqlite3
backend/logs/
backend/data/

# Rootless Docker data for the msm user (HOME=/opt/msm on prod). 
# git clean -fd would otherwise nuke containerd blobs / image layers if .local is untracked.
# This is what caused the "blob not found" / lease content errors after accidental clean.
.local/
.local/share/docker/
.local/share/containers/
/backend/.mypy_cache
frontend/frontend-dev.log
frontend/frontend-dev.err
backend-dev.log
backend-dev.err
PATCHNOTES-ms-oauth-feature.md
postgres/
/dis-sidecar/node_modules
.factory-test-env
/.cache

# MSM Backup Recovery (Tauri app)
/recovery/node_modules
/recovery/dist
/recovery/src-tauri/target
/recovery/src-tauri/gen
